  "keyFeatures": [
    "Safari tour browsing and booking",
    "User authentication with email verification",
    "Admin dashboard for content management",
    "Multi-category tour system",
    "Accommodations and events management",
    "Blog and media content",
    "Enquiry and booking management",
    "Products and services catalog",
    "Search functionality"
  ],
  "publicApiSurface": [
    "GET / - Home page",
    "GET /safaris - Browse safaris",
    "GET /tours/{category} - Tours by category",
    "GET /tours/categories/{sub_category} - Tours by subcategory",
    "GET /bookings/create/{destination} - Create booking",
    "POST /bookings/new - Store booking",
    "GET /accomodations - View accommodations",
    "GET /accomodation/{slug} - View accommodation details",
    "GET /events - View events",
    "GET /event/{slug} - View event details",
    "GET /products - View products",
    "GET /product/{slug} - View product details",
    "GET /services - View services",
    "GET /service/{slug} - View service details",
    "GET /blogs - View all blogs",
    "GET /blogs/show/{id} - View blog post",
    "POST /enquiries - Submit enquiry",
    "GET /search - Search tours",
    "Auth::routes - Authentication routes (login, register, password reset)",
    "GET /dashboard - Admin dashboard",
    "GET /profile - User profile"
  ]
